<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003" author="admin">
        <createTable tableName="rates">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="currency_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="country_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_rates_country" references="countries(id)"/>
            </column>
            <column name="rate_dict_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_rates_rate_dict" references="rate_dict(id)"/>
            </column>
            <column name="rate_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="nominal" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="value" type="DECIMAL(10,4)">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated" type="TIMESTAMP"/>
        </createTable>



        <createIndex indexName="idx_rates_currency_date" tableName="rates">
            <column name="currency_id"/>
            <column name="rate_date"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>